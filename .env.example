# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your values.
# ---------------------------------------------------------------------------

# Prisma reads DATABASE_URL at runtime. Use a *pooled* connection endpoint
# for the app (e.g. PgBouncer/Neon pooler) — best for Next.js serverless.
#
# Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require
#
# Example (Neon, pooled):
#   postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Direct (non-pooled) connection used ONLY by `prisma migrate`.
# Migrations run DDL, which pooled connections can reject. Neon: drop the
# "-pooler" segment from the host. Leave blank to reuse DATABASE_URL.
DATABASE_URL_DIRECT="postgresql://user:password@host:5432/dbname?sslmode=require"

# Public base URL of the running server, used to render the feed URL in the GUI.
# Omit the trailing slash. Example: http://localhost:3000
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
